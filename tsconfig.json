{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@data/*": [
        "src/data/*"
      ]
    },
    "types": [
      "expo-router/types"
    ]
  },
  "include": [
    "app",
    "src",
    "modules",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
